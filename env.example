# ============================================================
# exart.io — Environment Variables
# Copy to .env and fill in all values before running locally.
# Set all of these in Render → Environment for production.
# ============================================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — copy from Stripe Dashboard → Products
STRIPE_SOLO_PRICE_ID=price_...           # Solo-Lizenz €149/month
STRIPE_SOLO_YEARLY_PRICE_ID=price_...   # Solo-Lizenz yearly
STRIPE_EXPERT_PRICE_ID=price_...        # Expert-Lizenz €349/month
STRIPE_EXPERT_YEARLY_PRICE_ID=price_... # Expert-Lizenz yearly
STRIPE_UNIT_PRICE_ID=price_...          # Einzelgutachten €59 one-time
STRIPE_UNIT_SOLO_PRICE_ID=price_...     # Einzelgutachten €39 discount for solo subscribers

# Anthropic (AI generation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings only — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Resend (transactional email)
RESEND_API_KEY=re_...

# Admin dashboard access (set any strong random string)
ADMIN_SECRET=your_strong_random_secret_here

# Verification webhook — protects the internal verification approval endpoint
VERIFICATION_WEBHOOK_SECRET=your_strong_random_secret_here

# App
PORT=3000
FRONTEND_URL=https://exart.io

# Render — set automatically by Render, used for health-check ping in admin metrics
# RENDER_EXTERNAL_URL=https://exart-backend.onrender.com
